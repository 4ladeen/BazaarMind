# BazaarMind Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://bazaarmind:bazaarmind@localhost:5432/bazaarmind
DATABASE_URL_SYNC=postgresql://bazaarmind:bazaarmind@localhost:5432/bazaarmind

# AI API Keys (optional - system runs in demo mode without these)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_KEY=

# WhatsApp / Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Ollama (optional - for edge inference)
OLLAMA_BASE_URL=http://localhost:11434

# App Config
APP_ENV=development
APP_SECRET_KEY=bazaarmind-dev-secret-key-change-in-production
DEMO_MODE=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
